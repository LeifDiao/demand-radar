# This repository is a Claude Code plugin (config + prose + helper scripts),
# not a code library — hide the GitHub "Languages" bar by excluding everything
# from Linguist's language statistics.
*.html  linguist-documentation
*.md    linguist-documentation
*.py    linguist-detectable=false
*.json  linguist-detectable=false
*.css   linguist-detectable=false
*.js    linguist-detectable=false
*.txt   linguist-detectable=false

# The showcase report is machine-generated.
docs/sample-report.html linguist-generated
